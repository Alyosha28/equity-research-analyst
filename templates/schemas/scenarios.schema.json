{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://equity-research-analyst/schemas/scenarios",
  "title": "Triangulation Scenarios",
  "description": "Cross-check of all 7 valuation lenses produced by /triangulate. Captures the pattern of agreement vs disagreement across intrinsic DCF, Monte Carlo, breakeven, reverse DCF, comps, SOTP, and the bear case — from which the dispute locus and variant perception emerge.",
  "type": "object",
  "required": ["_meta", "lenses", "dispute_locus", "variant_perception", "verdict"],
  "properties": {
    "_meta": {
      "type": "object",
      "required": ["company", "ticker", "valuation_date", "archetype", "price"],
      "properties": {
        "company": { "type": "string", "description": "Full company name" },
        "ticker": { "type": "string", "description": "Exchange ticker" },
        "valuation_date": { "type": "string", "format": "date", "description": "ISO date YYYY-MM-DD" },
        "archetype": { "type": "string", "enum": ["default", "financials", "cyclical", "young", "mature", "holding-co"] },
        "price": { "type": "number", "description": "Current market price per share" },
        "currency": { "type": "string", "default": "USD" },
        "generated_by": { "type": "string", "default": "/triangulate" }
      }
    },

    "lenses": {
      "type": "object",
      "description": "The seven valuation lenses, each populated or marked N/A with reason.",
      "required": ["dcf", "monte_carlo", "breakeven", "reverse_dcf", "comps", "sotp", "bear"],
      "properties": {
        "dcf": {
          "type": "object",
          "required": ["label", "value_per_share", "terminal_pct", "signal"],
          "properties": {
            "label": { "const": "Intrinsic DCF" },
            "value_per_share": { "type": "number" },
            "terminal_pct": { "type": "number", "description": "Fraction of operating value in terminal (0-1)" },
            "premium_discount": { "type": "number", "description": "Value vs price (positive = undervalued %)" },
            "signal": { "type": "string", "enum": ["STRONG_BUY", "BUY", "FAIR", "SELL", "STRONG_SELL", "N/A"] },
            "key_driver_sensitivity": { "type": "string", "description": "Which single driver moves value most" }
          }
        },
        "monte_carlo": {
          "type": "object",
          "required": ["label", "median", "trials", "price_percentile", "signal"],
          "properties": {
            "label": { "const": "Monte Carlo" },
            "median": { "type": "number" },
            "mean": { "type": "number" },
            "p10": { "type": "number" },
            "p90": { "type": "number" },
            "trials": { "type": "integer", "minimum": 10000 },
            "price_percentile": { "type": "number", "description": "Where price sits in value distribution (0-1)" },
            "p_undervalued": { "type": "number", "description": "P(intrinsic >= price)" },
            "mos_accumulate_below": { "type": "number" },
            "mos_fair": { "type": "number" },
            "mos_rich_above": { "type": "number" },
            "signal": { "type": "string", "enum": ["STRONG_BUY", "BUY", "FAIR", "SELL", "STRONG_SELL", "N/A"] }
          }
        },
        "breakeven": {
          "type": "object",
          "required": ["label", "narrative", "signal"],
          "properties": {
            "label": { "const": "Breakeven" },
            "justifies_price_at": {
              "type": "object",
              "properties": {
                "y10_revenue_b": { "type": "number", "description": "Year-10 revenue in $billions to reach price at base margin" },
                "target_margin": { "type": "number", "description": "Target op margin to reach price at base revenue" }
              }
            },
            "narrative": { "type": "string", "description": "What must be true for current price" },
            "signal": { "type": "string", "enum": ["STRONG_BUY", "BUY", "FAIR", "SELL", "STRONG_SELL", "N/A"] }
          }
        },
        "reverse_dcf": {
          "type": "object",
          "required": ["label", "implied_revenue_b", "implied_margin", "signal"],
          "properties": {
            "label": { "const": "Reverse DCF" },
            "implied_revenue_b": { "type": "number", "description": "Y10 revenue implied by price ($billions)" },
            "base_revenue_b": { "type": "number", "description": "Base-case Y10 revenue ($billions)" },
            "uplift_pct": { "type": "number", "description": "Implied / base - 1" },
            "implied_margin": { "type": "number", "description": "Target op margin implied by price" },
            "base_margin": { "type": "number" },
            "implied_cagr": { "type": "number", "description": "Implied 10-year revenue CAGR" },
            "plausibility": { "type": "string", "enum": ["plausible", "stretched", "heroic", "impossible"] },
            "signal": { "type": "string", "enum": ["STRONG_BUY", "BUY", "FAIR", "SELL", "STRONG_SELL", "N/A"] }
          }
        },
        "comps": {
          "type": "object",
          "required": ["label", "range_low", "range_high", "median", "signal"],
          "properties": {
            "label": { "const": "Comps" },
            "range_low": { "type": "number" },
            "range_high": { "type": "number" },
            "median": { "type": "number" },
            "multiples_used": {
              "type": "array",
              "items": { "type": "string" },
              "description": "e.g. ['EV/EBITDA', 'P/E', 'PEG']"
            },
            "peer_set": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Peer tickers used"
            },
            "caveat": { "type": "string", "description": "Key caveat (e.g. trailing vs forward, cyclical distortion)" },
            "signal": { "type": "string", "enum": ["STRONG_BUY", "BUY", "FAIR", "SELL", "STRONG_SELL", "N/A"] }
          }
        },
        "sotp": {
          "type": "object",
          "required": ["label"],
          "properties": {
            "label": { "const": "SOTP" },
            "applicable": { "type": "boolean" },
            "reason_if_na": { "type": "string" },
            "sum_of_parts_value": { "type": "number" },
            "conglomerate_discount": { "type": "number", "description": "Discount applied to NAV (0-1)" },
            "pieces": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "value_per_share": { "type": "number" },
                  "method": { "type": "string" }
                }
              }
            },
            "signal": { "type": "string", "enum": ["STRONG_BUY", "BUY", "FAIR", "SELL", "STRONG_SELL", "N/A"] }
          }
        },
        "bear": {
          "type": "object",
          "required": ["label", "top_break_mechanisms"],
          "properties": {
            "label": { "const": "Bear Case" },
            "top_break_mechanisms": {
              "type": "array",
              "minItems": 1,
              "maxItems": 5,
              "items": {
                "type": "object",
                "required": ["mechanism", "trigger", "value_impact_pct"],
                "properties": {
                  "mechanism": { "type": "string", "description": "What breaks" },
                  "trigger": { "type": "string", "description": "Observable signal the break is happening" },
                  "value_impact_pct": { "type": "number", "description": "Estimated % haircut to base value" },
                  "plausibility": { "type": "string", "enum": ["low", "medium", "high"] }
                }
              }
            },
            "signal": { "type": "string", "enum": ["STRONG_BUY", "BUY", "FAIR", "SELL", "STRONG_SELL", "N/A"] }
          }
        }
      }
    },

    "dispute_locus": {
      "type": "object",
      "description": "Where the lenses agree and disagree — the dimension where the real bet sits.",
      "required": ["dimension", "driver", "market_view", "our_view", "agreement_pattern"],
      "properties": {
        "dimension": {
          "type": "string",
          "enum": ["near_term_execution", "terminal_durability", "cyclical_timing", "moat_width", "market_share_trajectory", "margin_structural_level"],
          "description": "near_term_execution = years 1-3; terminal_durability = years 5-10+"
        },
        "driver": { "type": "string", "description": "Specific driver: revenue_growth / target_operating_margin / CAP / terminal_roc / sales_to_capital" },
        "market_view": { "type": "string", "description": "What the current price implies the market believes" },
        "our_view": { "type": "string", "description": "What our analysis says" },
        "agreement_pattern": {
          "type": "object",
          "properties": {
            "agreeing_lenses": { "type": "array", "items": { "type": "string" } },
            "disagreeing_lenses": { "type": "array", "items": { "type": "string" } },
            "neutral_lenses": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },

    "variant_perception": {
      "type": "object",
      "description": "The specific, falsifiable claim you must out-predict the market on.",
      "required": ["claim", "falsification_condition", "time_horizon", "confidence"],
      "properties": {
        "claim": { "type": "string", "description": "The one thing you must be right about" },
        "falsification_condition": { "type": "string", "description": "What observable fact would prove this wrong" },
        "time_horizon": { "type": "string", "description": "e.g. 'next 2 earnings cycles', '3-5 years'" },
        "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
        "edge_rationale": { "type": "string", "description": "Why you can out-predict the market on this" }
      }
    },

    "verdict": {
      "type": "object",
      "description": "Triangulation verdict — never an average; an interpretation of the lens pattern.",
      "required": ["rating", "confidence", "diligence_concentration"],
      "properties": {
        "rating": { "type": "string", "enum": ["UNDERVALUED", "FAIRLY_VALUED", "OVERVAULED", "CANNOT_DETERMINE"] },
        "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
        "diligence_concentration": { "type": "string", "description": "The highest-ROI single question for further research" },
        "key_risk_to_verdict": { "type": "string", "description": "The one thing most likely to make this wrong" },
        "prose_summary": { "type": "string", "description": "300-500 word synthesis of the triangulation" }
      }
    }
  }
}
