      "h2_bottom": 8,
      "h3_top": 14,
      "h3_bottom": 6,
      "h4_top": 12,
      "h4_bottom": 4
    },
    "horizontal_rule_margin_pt": 18,
    "blockquote": {
      "margin_top_pt": 14,
      "margin_bottom_pt": 14,
      "margin_left_pt": 18,
      "padding_left_pt": 14,
      "border_width_pt": 2
    },
    "list": {
      "margin_top_pt": 8,
      "margin_bottom_pt": 8,
      "padding_left_pt": 22,
      "item_margin_bottom_pt": 3
    },
    "figure_margin_pt": 18,
    "figure_caption_margin_top_pt": 6,
    "rating_box": {
      "padding_pt": [18, 22],
