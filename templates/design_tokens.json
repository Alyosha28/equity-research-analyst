    "code_block": {
      "padding_pt": [12, 14],
      "margin_pt": [12, 0],
      "border_radius_pt": 4,
      "border_width_pt": 0.5
    },
    "table": {
      "margin_pt": [14, 0],
      "cell_padding_theader_pt": [6, 8, 4, 8],
      "cell_padding_tbody_pt": [4, 8],
      "header_border_bottom_pt": 1.5
    },
    "page_footer": {
      "border_top_pt": 0.5,
      "padding_top_pt": 6,
      "margin_top_pt": 6
    },
    "disclaimer": {
      "margin_top_pt": 28,
      "padding_top_pt": 10,
      "border_top_pt": 0.5
    },
    "toc": {
      "margin_pt": [22, 0],
      "item_margin_bottom_pt": 4,
      "h2_margin_top_pt": 8,
      "h3_margin_left_pt": 18
    }
  },

  "charts": {
    "figsize_inches": [9.0, 5.2],
    "dpi": 144,
    "donut_figsize_inches": [5.6, 5.6],
    "output_formats": ["png", "svg"],
    "histogram_bins": 60,
    "histogram_alpha": 0.55,
    "football_field_line_width": 9,
    "football_field_marker_size": 7,
    "tornado_alpha": 0.75,
    "donut_width": 0.42,
    "grid_line_width": 0.6,
    "grid_alpha": 0.7,
    "price_line_width": 2.0,
    "mos_band_line_width": 1.4,
    "median_line_width": 1.6,
    "base_line_width": 1.6,
    "spine_color": "#e5e7eb",
    "title_pad_pt": 12,
    "canonical_output_pattern": "figs/{TICKER}_{kind}.{ext}",
    "chart_kinds": ["montecarlo", "football", "breakeven", "tornado", "terminal"]
  },

  "pdf_output": {
    "max_file_size_mb": 5.0,
    "default_max_inline_svg_mb": 1.0,
    "cjk_line_height_multiplier": 1.75,
    "engine_priority_order": [
      "pandoc-weasyprint",
      "weasyprint",
      "playwright",
      "pandoc-only"
    ],
    "rendering_timeout_seconds": {
      "weasyprint": 120,
      "pandoc": 180,
      "playwright": 60
    },
    "markdown_extensions": [
      "tables",
      "fenced_code",
      "codehilite",
      "toc",
      "footnotes",
      "attr_list",
      "def_list"
    ]
  },

  "cjk": {
    "preferred_fonts": {
      "sans_serif": {
        "tier1": ["Noto Sans CJK SC", "Source Han Sans SC"],
        "tier2": {
          "windows": ["Microsoft YaHei", "SimHei", "Noto Sans SC"],
          "darwin": ["PingFang SC", "Hiragino Sans GB", "Noto Sans CJK SC"],
          "linux": ["Noto Sans CJK SC", "WenQuanYi Micro Hei"]
        }
      },
      "serif": {
        "tier1": ["Noto Serif CJK SC", "Source Han Serif SC"],
        "tier2": {
          "windows": ["SimSun", "NSimSun", "Noto Serif CJK SC"],
          "darwin": ["Songti SC", "STSong", "Noto Serif CJK SC"],
          "linux": ["Noto Serif CJK SC", "WenQuanYi Zen Hei"]
        }
      },
      "mono": {
        "tier1": ["Noto Sans Mono CJK SC"],
        "tier2": {
          "windows": ["SimHei", "SimSun"],
          "darwin": ["PingFang SC", "Hiragino Sans GB"],
          "linux": ["Noto Sans Mono CJK SC", "WenQuanYi Micro Hei"]
        }
      }
    },
    "unicode_ranges_for_css": [
      "U+2E80-2EFF",
      "U+3000-303F",
      "U+31C0-31EF",
      "U+3200-32FF",
      "U+3300-33FF",
      "U+3400-4DBF",
      "U+4E00-9FFF",
      "U+F900-FAFF",
      "U+FE10-FE1F",
      "U+FE30-FE4F",
      "U+FF00-FFEF",
      "U+20000-2A6DF",
      "U+2A700-2B73F",
      "U+2B740-2B81F",
      "U+2F800-2FA1F"
    ],
    "layout_adjustments": {
      "hanging_punctuation": "allow-end",
      "text_justify": "inter-character",
      "emphasis_style": "filled circle",
      "matplotlib_rcparams": {
        "axes.unicode_minus": false
      }
    }
  },

  "export": {
    "css_variable_prefix": "--",
    "chart_palette_keys": [
      "ink", "muted", "grid", "accent", "up", "down", "band", "surface"
    ],
    "chart_palette_js_export": {
      "ink": "#1f2a37",
      "muted": "#6b7280",
      "grid": "#e5e7eb",
      "accent": "#1d4ed8",
      "up": "#15803d",
      "down": "#b91c1c",
      "band": "#16a34a",
      "surface": "#f8fafc"
    },
    "md_to_html_classes": {
      "chart_figure": "chart",
      "chart_missing": "chart-missing",
      "rating_box": "rating-box",
      "disclaimer": "disclaimer",
      "numbers_ledger": "numbers-ledger",
      "toc": "toc",
      "landscape_page": "landscape",
      "two_col": "two-col",
      "page_break_before": "page-break-before",
      "page_break_after": "page-break-after",
      "keep_together": "keep-together",
      "wide_table": "wide",
